# OpenAI key used for the vision estimate call.
OPENAI_API_KEY=sk-...

# Path to the text file holding the estimator prompt template.
ESTIMATOR_PROMPT_FILE=estimator_prompt.txt

# Shared secret required in the `secret-sauce` request header.
# Leave unset to disable auth (local dev only).
API_KEY=

# Default OpenAI model when a request omits "model".
DEFAULT_MODEL=gpt-4.1

# Photos API used to resolve `rpId` -> photo list. Must contain {rp_id}.
PHOTOS_API_URL=https://calc.duo.tax/{rp_id}

# Optional Authorization header value sent to the photos API (calc.duo.tax needs none).
PHOTOS_API_AUTH=

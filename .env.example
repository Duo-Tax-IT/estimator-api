# Copy this file to .env (shared defaults) or .env.local (your real secrets).
# .env.local overrides .env and is git-ignored, so put live keys there.

# OpenAI key used for the vision estimate call.
OPENAI_API_KEY=sk-...

# Path to the text file holding the estimator prompt template.
ESTIMATOR_PROMPT_FILE=estimator_prompt.txt

# Shared secret required in the `secret-sauce` request header.
# Leave unset to disable auth (local dev only).
API_KEY=

# Default OpenAI model when a request omits "model".
# gpt-5.4-mini is a vision-capable reasoning model.
DEFAULT_MODEL=gpt-5.4-mini

# calc.duo.tax endpoint that resolves `rpId` -> photo list. Must contain {rp_id}.
# This is the ONLY source of photos (callers send rpId, never raw photos).
PHOTOS_API_URL=https://calc.duo.tax/property/{rp_id}/photos

# Optional Authorization header value sent to the photos API (calc.duo.tax needs none).
PHOTOS_API_AUTH=

# Megamind API base URL (the estimator-items path is appended in code), used to
# fetch the renovation-items catalog on every estimate. MEGAMIND_API_KEY is sent
# as the X-API-KEY header — put the real value in .env.local.
MEGAMIND_API_URL=https://api.megamind.duo.tax
MEGAMIND_API_KEY=
